{
  "ConnectionStrings": {
    "XpayConnection": "Server=<xpay-sql-qa>.database.windows.net;Database=XPAY_MVP_QA;User Id=<db-user>;Password=<db-password>;Encrypt=True;TrustServerCertificate=False;"
  },
  "Jwt": {
    "Key": "<QA_SECRET_KEY_MIN_32_CHARS_CAMBIAR_ANTES_DE_DESPLEGAR>",
    "Issuer": "Xpay.Api.QA",
    "Audience": "Xpay.Admin.QA",
    "ExpirationHours": 8
  },
  "Cors": {
    "AllowedOrigins": [
      "https://xpay-admin-qa.azurewebsites.net"
    ]
  },
  "Api": {
    "Name": "XPAY API QA",
    "Version": "0.1.0-mvp-qa"
  },
  "Observability": {
    "EnableRequestLogging": true,
    "EnableCorrelationId": true
  },
  "ApiDocs": {
    "EnableSwagger": true
  },
  "SecurityHeaders": {
    "EnableSecurityHeaders": true,
    "EnableNoStoreCache": true
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "LoginPermitLimit": 20,
    "LoginWindowSeconds": 60,
    "LoginQueueLimit": 0
  },
  "Audit": {
    "EnableAuditLogs": true
  },
  "AllowedHosts": "*"
}
