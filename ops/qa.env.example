# ================================================================
# XPAY QA local environment variables
# ops/qa.env.example
# ================================================================
#
# !! QA/dev only. No production. No real money. !!
#
# Copy this file to ops/qa.env.local and fill values locally.
# Do NOT commit ops/qa.env.local.
# Do NOT paste real tokens, passwords or IDs in this file.
#
# Usage:
#   cp ops/qa.env.example ops/qa.env.local
#   nano ops/qa.env.local      # fill values
#   source ops/qa.env.local
#   bash scripts/generate-qa-financial-ops.sh
#
# Full guide: docs/QA_OPERATIONS_VARIABLES.md
# ================================================================

# ----------------------------------------------------------------
# Backend base URL (no trailing slash)
# ----------------------------------------------------------------
export API_BASE="http://localhost:5000"

# ----------------------------------------------------------------
# JWT token — obtain via POST /api/auth/login
# SENSITIVE: do not commit, do not share
# ----------------------------------------------------------------
export TOKEN=""

# ----------------------------------------------------------------
# Wallet IDs — obtain via GET /api/admin/wallets after seed 008
# ----------------------------------------------------------------
export ID_WALLET_USUARIO_1=""
export ID_WALLET_USUARIO_2=""

# ----------------------------------------------------------------
# User ID (creadoPor field) — obtain via GET /api/admin/usuarios
# or from SQL: SELECT id_usuario, usuario FROM usuarios WHERE usuario = 'qa.admin.xpay';
# ----------------------------------------------------------------
export ID_USUARIO_QA=""

# ----------------------------------------------------------------
# Comercio ID — obtain via GET /api/admin/comercios after seed 008
# ----------------------------------------------------------------
export ID_COMERCIO_QA=""

# ----------------------------------------------------------------
# Optional — normally captured automatically by the script
# Set manually only if skipping earlier steps or retrying a step
# ----------------------------------------------------------------
export ID_VENTA_QR=""
export ID_RETIRO_1=""
export ID_RETIRO_2=""
